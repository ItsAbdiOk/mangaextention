{
  "manifest_version": 3,
  "name": "Manga Chapter Counter",
  "version": "2.1.0",
  "description": "Shows chapter counts and scanlation groups on AniList manga pages",
  "homepage_url": "https://github.com/ItsAbdiOk/mangaextention",
  "permissions": ["declarativeNetRequest"],
  "host_permissions": [
    "https://graphql.anilist.co/*",
    "https://series.naver.com/*",
    "https://www.webtoons.com/*",
    "https://webtoons.com/*",
    "https://comic.naver.com/*",
    "https://page.kakao.com/*",
    "https://webtoon.kakao.com/*",
    "https://tapas.io/*",
    "https://kadocomi.jp/*",
    "https://pocket.shonenmagazine.com/*",
    "https://comic-walker.com/*",
    "https://api.mangaupdates.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://anilist.co/manga/*"],
      "js": ["parsers.js", "content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
